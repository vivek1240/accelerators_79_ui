PORT=4000
MONGODB_URI=
JWT_SECRET=change-me-in-production
# ACCESS_TOKEN_JWT_SECRET: use the same HS256 secret as the client auth service. When set, GET /user-uploads
# requires a valid access_token cookie (no ?user_id=). Upload prefers cookie sub over body user_id.
# ACCESS_TOKEN_JWT_SECRET=
# Emergency: disable per-user file_id checks on the proxy (not recommended in production)
# PROXY_SKIP_FILE_OWNERSHIP=true
JWT_EXPIRE_DAYS=7
# Sent to FastAPI as user_id on /upload and /query when not using per-user auth
ANONYMOUS_USER_ID=

# FastAPI (agentic router) base URL for /route, /upload, /query, edgar, extract, etc.
# Local: use http (not https) to avoid EPROTO/SSL "packet length too long" error
FASTAPI_URL=http://localhost:8000
# Production: FASTAPI_URL=https://agentic-router-production-aa61.up.railway.app
# Optional if your FastAPI requires it:
# FASTAPI_API_KEY=your-api-key-from-env
